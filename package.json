{
  "name": "@betanyc/nys-openlegislation-mcp",
  "version": "2.0.1",
  "description": "MCP server for New York State legislation via the NYS Open Legislation API",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-assistant",
    "new-york",
    "new-york-state",
    "nys",
    "civic-tech",
    "open-data",
    "open-government",
    "betanyc",
    "legislation",
    "bills",
    "laws",
    "senate",
    "assembly",
    "state-legislature",
    "open-legislation",
    "nysenate"
  ],
  "license": "MIT",
  "author": "BetaNYC",
  "homepage": "https://github.com/BetaNYC/nys-openlegislation-mcp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BetaNYC/nys-openlegislation-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/BetaNYC/nys-openlegislation-mcp/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "nys-openlegislation-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepare": "npm run build",
    "fetch-data": "node scripts/fetch-data.js",
    "sync": "node scripts/sync.js",
    "test": "npm run build && node --test test/*.test.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^12.10.0",
    "zod": "^3.23.0"
  },
  "overrides": {
    "hono": ">=4.12.25 <5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18"
  }
}
